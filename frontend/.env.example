# Frontend build-time variables (Vite). Copy to .env locally; set in Cloudflare Pages → Settings → Environment variables.

# Optional: backend base URL with no trailing slash. Leave unset for local dev (Vite proxies /api to localhost:8000).
# VITE_API_BASE_URL=https://your-api.example.com

# Optional: Google Sign-In (must match backend Google OAuth client)
# VITE_GOOGLE_CLIENT_ID=

