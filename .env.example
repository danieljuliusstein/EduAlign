# EduAlign environment variables (optional for local dev)
# Copy this file to .env and fill in values. Do not commit .env.
# The app runs without .env using defaults; these are for OAuth, APIs, and debugging.

# Database (default: SQLite file in project root, works on Windows/macOS/Linux)
# DATABASE_URL=sqlite:///path/to/edualign.db

# Production (Postgres — Neon, Supabase, Railway, etc.; requires psycopg2-binary in requirements.txt):
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Browser origins allowed to call the API (comma-separated). Required in production when the
# frontend is on another host (e.g. Cloudflare Pages). Example:
# CORS_ORIGINS=https://your-app.pages.dev,https://yourdomain.com

# Auth: set a strong secret in production
# JWT_SECRET=your-secret-here

# Optional: Google Sign-In (leave empty to disable)
# GOOGLE_CLIENT_ID=

# Optional: Sign in with Apple (leave empty to disable)
# APPLE_CLIENT_ID=

# Optional: LLM / matching (leave unset to use fallback matching)
# GROQ_API_KEY=
# GEMINI_API_KEY=

# Optional: show detailed 500 error messages (developers only)
# EDUALIGN_DEBUG=1
# DEBUG=1

